# =====================================
# 📋 TEMPLATE DE VARIÁVEIS DE AMBIENTE
# =====================================
# 
# Este arquivo serve como template para configurar as variáveis de ambiente.
# 
# 🔧 COMO USAR:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais (sem aspas duplas desnecessárias)
# 3. NUNCA commite arquivos .env com dados reais!
#
# 📚 DOCUMENTAÇÃO: docs/estudo/02-docker-conceitos-fundamentais.md
# =====================================

# ==================
# 🌍 AMBIENTE GERAL
# ==================
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001

# ==================
# 🗄️ BANCO DE DADOS
# ==================
# Para desenvolvimento local com Neon/Supabase
DATABASE_URL=postgresql://username:password@host:5432/database_name?sslmode=require
DIRECT_URL=postgresql://username:password@host:5432/database_name?sslmode=require

# Para desenvolvimento local com PostgreSQL local
# DATABASE_URL=postgresql://postgres:password@localhost:5432/barbershop_dev
# DIRECT_URL=postgresql://postgres:password@localhost:5432/barbershop_dev

# ==================
# 🔐 AUTENTICAÇÃO
# ==================
# NextAuth.js - Gere com: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-super-secret-key-here-32-chars-min

# ==================
# 📧 CONFIGURAÇÃO DE EMAIL
# ==================
# Gmail (desenvolvimento)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Configurações SMTP alternativas (descomente se necessário)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# ==================
# 🔑 OAUTH PROVIDERS
# ==================
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (opcional) - https://github.com/settings/developers
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ==================
# 💳 PAGAMENTOS (OPCIONAL)
# ==================
# Stripe - https://dashboard.stripe.com/apikeys
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ==================
# 📊 ANALYTICS (OPCIONAL)
# ==================
# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==================
# 🚀 DEPLOY/PRODUÇÃO
# ==================
# Vercel/Netlify
# VERCEL_URL=your-app.vercel.app
# NEXT_PUBLIC_VERCEL_URL=https://your-app.vercel.app

# ==================
# 🔧 DESENVOLVIMENTO
# ==================
# Debug e logs
DEBUG=false
LOG_LEVEL=info
DEBUG_API_TOKEN=replace-with-strong-random-token

# Hot reload e desenvolvimento
FAST_REFRESH=true
NEXT_TELEMETRY_DISABLED=1

# Segurança de build/header (produção)
# ALLOW_UNSAFE_BUILD=0
# DISABLE_CSP_HEADER=0

# ==================
# 📝 NOTAS IMPORTANTES
# ==================
#
# 🔒 SEGURANÇA:
# - NUNCA commite este arquivo com valores reais
# - Use senhas de aplicativo para Gmail, não sua senha pessoal
# - Gere secrets únicos para cada ambiente
#
# 🌍 AMBIENTES:
# - .env.local → desenvolvimento local
# - .env.staging → homologação
# - .env.production → produção
#
# 🔗 LINKS ÚTEIS:
# - Gmail App Passwords: https://myaccount.google.com/apppasswords
# - Google Cloud Console: https://console.cloud.google.com/
# - OpenSSL para secrets: openssl rand -base64 32
#
# ==================
